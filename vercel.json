:root {
  --bg: #07111f;
  --panel: rgba(8, 17, 32, 0.82);
  --panel-2: rgba(13, 26, 49, 0.78);
  --line: rgba(145, 199, 255, 0.18);
  --text: #f2f6ff;
  --muted: #9fb3d7;
  --cyan: #69f0ff;
  --purple: #8c6bff;
  --pink: #ff71b9;
  --green: #53f08e;
  --yellow: #ffd35b;
  --red: #ff657c;
  --shadow: 0 24px 80px rgba(0, 0, 0, 0.35);
  font-family: Inter, Pretendard, "Segoe UI", sans-serif;
}

* { box-sizing: border-box; }
html, body { margin: 0; min-height: 100%; background: radial-gradient(circle at top, #102649 0%, #081120 48%, #040811 100%); color: var(--text); }
body { position: relative; overflow-x: hidden; }
button { font: inherit; border: 0; cursor: pointer; }

.aurora {
  position: fixed; inset: -20%; pointer-events: none; z-index: 0;
  background:
    radial-gradient(circle at 10% 10%, rgba(120, 108, 255, 0.22), transparent 28%),
    radial-gradient(circle at 90% 15%, rgba(98, 235, 255, 0.15), transparent 30%),
    radial-gradient(circle at 50% 90%, rgba(255, 112, 185, 0.12), transparent 28%);
  filter: blur(24px);
}

.layout {
  position: relative; z-index: 1;
  width: min(1500px, calc(100% - 32px));
  margin: 16px auto;
  display: grid;
  grid-template-columns: 320px minmax(0, 1fr) 360px;
  gap: 16px;
}

.panel {
  background: linear-gradient(180deg, var(--panel) 0%, var(--panel-2) 100%);
  border: 1px solid var(--line);
  border-radius: 28px;
  box-shadow: var(--shadow);
  backdrop-filter: blur(14px);
}

.hero-card, .control-card { padding: 24px; }
.hero-card { display: flex; flex-direction: column; gap: 16px; }
.eyebrow { color: var(--cyan); font-size: 12px; letter-spacing: 0.22em; text-transform: uppercase; }
.hero-card h1, .dialog h2, .control-card h2 { margin: 0; font-size: 34px; line-height: 1.08; }
.intro { margin: 0; color: var(--text); font-size: 18px; line-height: 1.6; }
.hero-tags { display: flex; flex-wrap: wrap; gap: 10px; }
.hero-tags span, .badge {
  display: inline-flex; align-items: center; justify-content: center;
  padding: 9px 14px; border-radius: 999px; border: 1px solid rgba(135, 202, 255, 0.22);
  color: var(--muted); background: rgba(255, 255, 255, 0.04);
}
.hero-actions, .dialog-actions { display: flex; gap: 10px; flex-wrap: wrap; }
.primary, .secondary {
  padding: 13px 18px; border-radius: 16px; font-weight: 700; transition: transform 0.16s ease, opacity 0.16s ease;
}
.primary { background: linear-gradient(135deg, var(--cyan), var(--purple)); color: #07111f; }
.secondary { background: rgba(255,255,255,0.06); color: var(--text); border: 1px solid rgba(255,255,255,0.08); }
.primary:hover, .secondary:hover { transform: translateY(-1px); }
.subnote { margin: 0; color: var(--muted); line-height: 1.6; font-size: 14px; }

.scene-card {
  position: relative; min-height: 860px; overflow: hidden;
  border-radius: 32px;
}
#sim-canvas { width: 100%; height: 100%; display: block; }
.hud {
  position: absolute; left: 18px; right: 18px; display: flex; justify-content: space-between; gap: 12px; pointer-events: none;
}
.hud-top { top: 18px; align-items: start; }
.hud-bottom { bottom: 18px; align-items: end; }
.pill {
  background: rgba(6, 14, 27, 0.74); border: 1px solid rgba(149, 209, 255, 0.14); border-radius: 18px;
  padding: 12px 16px; min-width: 110px; display: flex; align-items: baseline; gap: 8px;
}
.pill.big { min-width: 160px; }
.pill .label, .mission-title, .score-board span { color: var(--muted); font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; }
.pill span:not(.label):not(.unit) { font-size: 24px; font-weight: 800; }
.pill .unit { font-size: 14px; color: var(--muted); }

.mission-box, .feedback-box {
  width: min(42%, 360px); background: rgba(6, 14, 27, 0.78); border: 1px solid rgba(149, 209, 255, 0.14);
  border-radius: 18px; padding: 14px 16px;
}
#mission-value, #feedback-value { margin-top: 6px; line-height: 1.5; font-size: 15px; }
.score-board {
  position: absolute; right: 18px; top: 98px; display: grid; gap: 10px; pointer-events: none;
}
.score-board > div {
  min-width: 140px; padding: 12px 14px; border-radius: 16px; background: rgba(6, 14, 27, 0.78);
  border: 1px solid rgba(149, 209, 255, 0.14);
}
.score-board strong { display: block; margin-top: 4px; font-size: 26px; }

.control-card { display: flex; flex-direction: column; gap: 18px; }
.control-header { display: flex; align-items: start; justify-content: space-between; gap: 12px; }
.webcam-box {
  position: relative; aspect-ratio: 4 / 3; background: #030711; border-radius: 22px; overflow: hidden; border: 1px solid rgba(135,202,255,0.15);
}
#webcam, #hand-overlay {
  position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; transform: scaleX(-1);
}
.camera-status {
  position: absolute; left: 12px; right: 12px; bottom: 12px; padding: 10px 12px; border-radius: 12px;
  background: rgba(0,0,0,0.52); font-size: 14px;
}
.wheel-panel {
  background: rgba(255,255,255,0.03); border: 1px solid rgba(135,202,255,0.15); border-radius: 24px; padding: 16px;
}
#wheel-visual {
  width: min(100%, 280px); display: block; margin: 0 auto 12px auto; transform-origin: center center;
  filter: drop-shadow(0 18px 30px rgba(0,0,0,0.4));
}
.wheel-readout { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 10px; }
.wheel-readout > div { background: rgba(8,17,32,0.72); border-radius: 16px; padding: 10px 12px; border: 1px solid rgba(135,202,255,0.12); }
.wheel-readout span, .result-grid span { color: var(--muted); font-size: 12px; text-transform: uppercase; }
.wheel-readout strong, .result-grid strong { display: block; margin-top: 6px; font-size: 22px; }
.tip-list { display: grid; gap: 12px; }
.tip-item { display: grid; grid-template-columns: 34px 1fr; gap: 12px; align-items: start; }
.tip-item span {
  width: 34px; height: 34px; border-radius: 50%; display: grid; place-items: center; background: linear-gradient(135deg, var(--purple), var(--pink)); font-weight: 800;
}
.tip-item p { margin: 0; color: var(--muted); line-height: 1.55; }

.overlay {
  position: fixed; inset: 0; background: rgba(1, 5, 12, 0.65); display: none; place-items: center; z-index: 20; padding: 20px;
}
.overlay.active { display: grid; }
.dialog { width: min(560px, 100%); padding: 28px; }
.dialog p { color: var(--muted); line-height: 1.7; }
.result-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 12px; margin: 18px 0 22px; }
.result-grid > div { padding: 14px; border-radius: 18px; background: rgba(255,255,255,0.04); border: 1px solid rgba(135,202,255,0.12); }

@media (max-width: 1260px) {
  .layout { grid-template-columns: 1fr; }
  .scene-card { min-height: 680px; }
}

@media (max-width: 760px) {
  .layout { width: min(100% - 20px, 100%); margin: 10px auto; gap: 12px; }
  .hero-card h1, .dialog h2, .control-card h2 { font-size: 28px; }
  .scene-card { min-height: 580px; }
  .score-board { position: static; grid-template-columns: repeat(2, minmax(0, 1fr)); padding: 18px; }
  .hud-top, .hud-bottom { position: static; padding: 18px; flex-direction: column; }
  .mission-box, .feedback-box { width: 100%; }
  .result-grid, .wheel-readout { grid-template-columns: 1fr; }
}
